# Apache / cPanel — Prakasha PWA v7
Options -MultiViews
RewriteEngine On

# Service worker: no-cache so updates are immediate
<Files "service-worker.js">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Service-Worker-Allowed "/"
</Files>

# Manifest + index: always fresh
<FilesMatch "^(manifest\.json|index\.html)$">
  Header set Cache-Control "public, max-age=0, must-revalidate"
</FilesMatch>

# Keygen: no-cache (admin tool — never serve stale)
<Files "keygen.html">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set X-Robots-Tag "noindex, nofollow"
</Files>

# Icons: long-lived immutable cache
<FilesMatch "\.(png|ico|svg|webp)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# SPA routing: unknown paths → index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]
